# CONFIG_SDK is not set
# CONFIG_IB is not set
# CONFIG_MAKE_TOOLCHAIN is not set

# ---------------------------------
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y

